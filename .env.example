# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/hotel_agent_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Google Maps API Key (for location services)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Booking.com API (if available)
BOOKING_API_KEY=your_booking_api_key_here
BOOKING_API_URL=https://distribution-xml.booking.com/2.5/json

# Airbnb API (if available)
AIRBNB_API_KEY=your_airbnb_api_key_here
AIRBNB_API_URL=https://api.airbnb.com/v2

# Application Settings
APP_NAME=Hotel Response Agent
DEBUG=True
HOST=0.0.0.0
PORT=8000